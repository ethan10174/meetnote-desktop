{
  "name": "meetnote-desktop",
  "version": "1.1.0",
  "description": "MeetNote – AI meeting recorder and summarizer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-native": "bash build-native.sh",
    "dist": "npm run build-native && electron-builder --mac --publish never",
    "dist-win": "electron-builder --win"
  },
  "build": {
    "appId": "com.meetnote.app",
    "productName": "MeetNote",
    "afterSign": "notarize.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "native-bridge.js",
      "notarize.js",
      "entitlements.mac.plist",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/audio-recorder",
        "to": "audio-recorder"
      }
    ],
    "mac": {
      "extraResources": [
        { "from": "node_modules/ffmpeg-static/ffmpeg", "to": "ffmpeg" }
      ],
      "identity": "ETHAN ALLISON (GMVTGR644V)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": false,
      "icon": "icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "extraResources": [
        { "from": "node_modules/ffmpeg-static/ffmpeg.exe", "to": "ffmpeg.exe" },
        { "from": "native/audio_capture.exe", "to": "audio_capture.exe" }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon-256.png"
    },
    "dmg": {
      "title": "MeetNote",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "ffmpeg-static": "^5.3.0",
    "node-record-lpcm16": "^1.0.1"
  }
}
